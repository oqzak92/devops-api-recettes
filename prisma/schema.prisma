generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Recette {
  id                Int      @id @default(autoincrement())
  titre             String
  description       String?
  ingredients       String
  temps_preparation Int
  difficulte        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
